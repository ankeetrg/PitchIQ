# PitchIQ — environment variables. Copy to .env.local and fill in. Never commit real keys.

# Analytics (optional). GA4 measurement ID, e.g. G-XXXXXXXXXX.
# Public by design — safe to expose client-side. Leave unset to disable GA4.
NEXT_PUBLIC_GA_ID=

# Newsletter provider (server-only). If either is unset, signups are accepted
# by the UI but NOT stored — see app/api/newsletter/route.ts.
NEWSLETTER_API_URL=
NEWSLETTER_API_KEY=
